generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// *
///  * Usuario del sistema.
///  *
///  * Puede ser administrador o vendedor.
///  *
///  * Un vendedor puede registrar muchos pedidos generales.
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(SELLER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("users")
}

/// *
///  * Producto disponible para vender.
///  *
///  * En este proyecto el producto puede crearse automáticamente
///  * cuando se registra un pedido.
///  *
///  * El SKU es el código/número del artículo dentro del catálogo.
model Product {
  id          Int         @id @default(autoincrement())
  sku         String      @unique
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@map("products")
}

/// *
///  * Cliente/comprador.
///  *
///  * No se borra porque puede volver a comprar
///  * y porque sus pedidos anteriores deben conservarse como historial.
model Customer {
  id             Int             @id @default(autoincrement())
  name           String
  phone          String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  customerOrders CustomerOrder[]

  @@map("customers")
}

/// *
///  * Pedido general.
///  *
///  * Representa una captura completa de pedido.
///  *
///  * Nueva lógica:
///  * - Un pedido general puede tener varios clientes.
///  * - Cada cliente dentro del pedido tiene sus propios artículos.
///  *
///  * Ejemplo:
///  * Pedido general #1
///  * - Cliente María
///  *   - Perfume x2
///  * - Cliente Juan
///  *   - Crema x1
///  *
///  * Beneficio:
///  * - Permite capturar pedidos tipo catálogo.
///  * - Mantiene el total completo del pedido.
///  * - Permite separar cuánto debe cada cliente.
model Order {
  id             Int             @id @default(autoincrement())
  sellerId       Int
  total          Decimal         @db.Decimal(10, 2)
  status         OrderStatus     @default(PENDING)
  purchaseDate   DateTime        @default(now())
  deliveryDate   DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  customerOrders CustomerOrder[]
  seller         User            @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@map("orders")
}

/// *
///  * Pedido de un cliente dentro de un pedido general.
///  *
///  * Este modelo une:
///  * - Order general
///  * - Customer
///  *
///  * Ejemplo:
///  * Pedido general #1
///  * - CustomerOrder de María
///  * - CustomerOrder de Juan
///  *
///  * Beneficio:
///  * - Permite saber cuánto pidió cada cliente.
///  * - Permite consultar historial por cliente.
///  * - Permite separar artículos por persona dentro del mismo pedido.
///  * - Ahora también permite guardar abonos por cliente.
model CustomerOrder {
  id         Int                    @id @default(autoincrement())
  orderId    Int
  customerId Int
  total      Decimal                @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  customer   Customer               @relation(fields: [customerId], references: [id])
  order      Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items      OrderItem[]
  payments   CustomerOrderPayment[]

  @@unique([orderId, customerId])
  @@index([orderId])
  @@index([customerId])
  @@map("customer_orders")
}

/// *
///  * Detalle de pedido.
///  *
///  * Cada registro representa un artículo comprado por un cliente
///  * dentro de un pedido general.
///  *
///  * Nueva lógica:
///  * - Ya no apunta directo a Order.
///  * - Ahora apunta a CustomerOrder.
///  *
///  * Beneficio:
///  * - Sabemos exactamente qué artículos pidió cada cliente.
model OrderItem {
  id                  Int           @id @default(autoincrement())
  customerOrderId     Int
  productId           Int?
  skuSnapshot         String
  nameSnapshot        String
  descriptionSnapshot String?
  unitPriceSnapshot   Decimal       @db.Decimal(10, 2)
  quantity            Int
  subtotal            Decimal       @db.Decimal(10, 2)

  /// *
  ///  * Indica si este artículo individual ya fue pagado.
  ///  *
  ///  * Para qué sirve:
  ///  * - Permite marcar artículos pagados sin marcar todo el pedido como pagado.
  ///  *
  ///  * Beneficio:
  ///  * - Un cliente puede pagar algunos artículos primero y otros después.
  isPaid              Boolean       @default(false)

  customerOrder       CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  product             Product?      @relation(fields: [productId], references: [id])

  @@index([customerOrderId])
  @@index([productId])
  @@index([skuSnapshot])
  @@map("order_items")
}

/// *
///  * Pagos/abonos realizados por un cliente dentro de un pedido.
///  *
///  * Para qué sirve:
///  * - Permite registrar pagos parciales o completos de un cliente específico.
///  * - Un cliente dentro del pedido puede tener varios abonos.
///  *
///  * Ejemplo:
///  * Pedido #1
///  * - María debe $500
///  *   - Abono $200 efectivo
///  *   - Pendiente $300
///  * - Juan debe $800
///  *   - Abono $800 transferencia
///  *   - Pendiente $0
///  *
///  * Beneficio:
///  * - Sabemos exactamente qué cliente pagó.
///  * - Podemos calcular pagado y pendiente por cliente.
///  * - Conservamos historial de abonos por cliente dentro del pedido.
model CustomerOrderPayment {
  id              Int           @id @default(autoincrement())
  customerOrderId Int
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod @default(CASH)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customerOrder   CustomerOrder @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)

  @@index([customerOrderId])
  @@map("customer_order_payments")
}

/// *
///  * Roles del sistema.
///  *
///  * ADMIN:
///  * Puede administrar productos, usuarios y revisar todo.
///  *
///  * SELLER:
///  * Puede registrar clientes y pedidos.
enum UserRole {
  ADMIN
  SELLER
}

/// *
///  * Estados de un pedido.
///  *
///  * PENDING:
///  * Pedido registrado, pero aún no pagado o finalizado.
///  *
///  * PAID:
///  * Pedido pagado.
///  *
///  * DELIVERED:
///  * Pedido entregado.
///  *
///  * CANCELLED:
///  * Pedido cancelado.
enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  CANCELLED
}

/// *
///  * Métodos de pago.
///  *
///  * CASH:
///  * Pago en efectivo.
///  *
///  * TRANSFER:
///  * Pago por transferencia.
///  *
///  * CARD:
///  * Pago con tarjeta.
///  *
///  * OTHER:
///  * Otro método de pago.
enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}